{
  "$schema": "https://github.com/Azure/data-api-builder/releases/download/v1.7.93/dab.draft.schema.json",
  "data-source": {
    "database-type": "mssql",
    "connection-string": "@env('MSSQL_CONNECTION_STRING')",
    "options": {
      "set-session-context": false
    }
  },
  "runtime": {
    "rest": {
      "enabled": true,
      "path": "/api",
      "request-body-strict": true
    },
    "graphql": {
      "enabled": true,
      "path": "/graphql",
      "allow-introspection": true
    },
    "mcp": {
      "enabled": true,
      "path": "/mcp"
    },
    "host": {
      "cors": {
        "origins": [],
        "allow-credentials": false
      },
      "authentication": {
        "provider": "AppService"
      },
      "mode": "development"
    }
  },
  "entities": {
    "Customers": {
      "description": "Customer records including names, emails, account status, regions, and annual premiums",
      "source": {
        "object": "dbo.Customers",
        "type": "table"
      },
      "graphql": {
        "enabled": true,
        "type": {
          "singular": "Customers",
          "plural": "Customers"
        }
      },
      "rest": {
        "enabled": true
      },
      "permissions": [
        {
          "role": "anonymous",
          "actions": [
            {
              "action": "read"
            }
          ]
        }
      ]
    },
    "CarrierColumnMetadata": {
      "description": "Carrier column metadata mapping source columns to destination columns across insurance carriers and lines of business",
      "source": {
        "object": "dbo.CarrierColumnMetadata",
        "type": "table"
      },
      "graphql": {
        "enabled": true,
        "type": {
          "singular": "CarrierColumnMetadata",
          "plural": "CarrierColumnMetadatas"
        }
      },
      "rest": {
        "enabled": true
      },
      "permissions": [
        {
          "role": "anonymous",
          "actions": [
            {
              "action": "read"
            }
          ]
        }
      ]
    },
    "SchemaDriftStaging": {
      "description": "Staging table for incoming insurance data files that may have schema drift from expected column formats",
      "source": {
        "object": "dbo.SchemaDriftStaging",
        "type": "table"
      },
      "graphql": {
        "enabled": true,
        "type": {
          "singular": "SchemaDriftStaging",
          "plural": "SchemaDriftStagings"
        }
      },
      "rest": {
        "enabled": true
      },
      "permissions": [
        {
          "role": "anonymous",
          "actions": [
            {
              "action": "read"
            }
          ]
        }
      ]
    }
  }
}